<section class="max-w-xl">
  <h2 class="text-xl font-bold text-gray-900 mb-2">Step 3 — Telegram bot</h2>
  <p class="text-sm text-gray-600 mb-6">
    Telegram is the default integration. Skip it (leave blank) if you only
    want the web UI.
  </p>

  <details class="mb-6 border border-gray-200 rounded-lg overflow-hidden">
    <summary class="px-4 py-3 text-sm font-medium text-gray-700 bg-gray-50 cursor-pointer hover:bg-gray-100">
      How to get a bot token</summary>
    <div class="px-4 py-3 text-sm text-gray-600">
      <ol class="list-decimal list-inside space-y-1">
        <li>Open Telegram, message <a href="https://t.me/BotFather" target="_blank" rel="noopener">@BotFather</a>.</li>
        <li>Send <code>/newbot</code>. Pick a name and a username (must end in <code>bot</code>).</li>
        <li>BotFather replies with a token like <code>123456:ABC-DEF...</code>. Paste it below.</li>
        <li>Message <a href="https://t.me/userinfobot" target="_blank" rel="noopener">@userinfobot</a> to get
          your numeric user ID. That goes in the second field.</li>
      </ol>
    </div>
  </details>

  <form hx-post="/setup/save/telegram"
        hx-target="#wizard"
        hx-swap="innerHTML">
    <label class="block mb-6">
      <span class="block text-sm font-medium text-gray-700 mb-1">Bot token</span>
      <input name="token" id="tg-token" type="text"
             placeholder="123456:ABC-DEF..."
             value="{{ token }}"
             autocomplete="off"
             spellcheck="false"
             class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 bg-white">
    </label>

    <label class="block mb-6">
      <span class="block text-sm font-medium text-gray-700 mb-1">Your Telegram user IDs (comma-separated)</span>
      <input name="allowed_user_ids" type="text"
             placeholder="123456789"
             value="{{ allowed_user_ids }}"
             autocomplete="off"
             spellcheck="false"
             class="block w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 bg-white">
      <small class="block text-xs text-gray-500 mt-1">Only these users can talk to the bot. The bridge ignores everyone else.</small>
    </label>

    <div class="flex items-center gap-3 mb-6">
      <button type="button"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50"
              hx-post="/setup/test/telegram"
              hx-include="#tg-token"
              hx-target="#tg-test-result"
              hx-swap="innerHTML">
        Test token
      </button>
      <span id="tg-test-result" class="text-sm"></span>
    </div>

    <div class="flex gap-3 mt-6">
      <button type="button"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50"
              hx-get="/setup/step/identity"
              hx-target="#wizard"
              hx-swap="innerHTML">← Back</button>
      <button type="submit"
              class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">
        Save and continue →</button>
    </div>
  </form>
</section>
